# Server Configuration
PORT=3000

# External API Configuration
API_BASE_URL=https://your-api-base-url.com
MERCHANT_USERNAME=your-merchant-username
MERCHANT_API_KEY=your-merchant-api-key

# Feature Flags
USE_MOCK_API=true

# Google Cloud Vision API (for OCR functionality)
CLOUD_VISION_URL=https://vision.googleapis.com/v1/images:annotate?key=
CLOUD_VISION_API_KEY=your-google-cloud-vision-api-key

# Payment Gateway Configuration
PAYMENT_CLIENT_ID=your-payment-client-id
PAYMENT_STORE_KEY=your-payment-store-key
PAYMENT_GATE_URL=https://your-payment-gateway.com
PAYMENT_OK_URL=https://your-domain.com/api/payment/response
PAYMENT_FAIL_URL=https://your-domain.com/api/payment/response
PAYMENT_CALLBACK_URL=https://your-domain.com/api/payment/callback

# CORS Configuration (optional - defaults to allow all)
# ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com